{
  "name": "darknes-monorepo",
  "private": true,
  "version": "0.1.0",
  "description": "DARKNES — cinematic visual novel engine and game, monorepo root",
  "scripts": {
    "dev": "turbo run dev --filter=@darknes/game",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "format": "prettier --write \"**/*.{ts,tsx,json,md}\""
  },
  "devDependencies": {
    "turbo": "^2.1.3",
    "prettier": "^3.3.3",
    "typescript": "^5.6.3",
    "eslint": "^8.57.1",
    "@typescript-eslint/eslint-plugin": "^8.8.1",
    "@typescript-eslint/parser": "^8.8.1",
    "eslint-plugin-react-hooks": "^4.6.2",
    "eslint-plugin-react-refresh": "^0.4.12"
  },
  "packageManager": "pnpm@9.12.0",
  "engines": {
    "node": ">=18.18.0"
  }
}
