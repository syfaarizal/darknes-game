                      "id":  "scene09_n001",
                      "type":  "narration",
                      "text":  "Rumah kembali sunyi. {playerName} duduk di depan meja kerjanya. Di atas meja tergeletak sebuah map bertuliskan: Victor Hale. Tak lama kemudian, suara pintu balkon kembali terbuka. Nathael masuk sambil membawa dua cangkir kopi. Ia meletakkan salah satunya di meja.",
                      "next":  "scene09_n002"
                  },
                  {
                      "id":  "scene09_n002",
                      "type":  "line",
                      "speaker":  "nathael",
                      "expression":  "smile",
                      "characters":  [
                                         {
                                             "characterId":  "nathael",
                                             "expression":  "smile",
                                             "position":  "center",
                                             "isSpeaking":  true
                                         }
                                     ],
                      "text":  "Kopi. Biar matamu nggak kalah sama laporan itu.",
                      "next":  "scene09_n003"
