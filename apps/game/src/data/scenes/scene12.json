                {
                    "characterId": "alaric",
                    "expression": "neutral",
                    "position": "center",
                    "isSpeaking": true
                }
            ],
            "text": "(tersenyum pahit) Selama ini... yang kamu ajak bicara... nggak pernah bisa kami lihat. Kami diam... karena kami takut kamu semakin hancur.",
            "next": "scene12_n016"
        },
        {
            "id": "scene12_n016",
            "type": "narration",
            "text": "{playerName} menoleh ke arah lorong. Kosong. Air matanya perlahan jatuh.",
            "next": "scene12_n017"
        },
        {
            "id": "scene12_n017",
            "type": "line",
            "speaker": "{playerName}",
            "expression": "neutral",
            "characters": [
                {
                    "characterId": "alaric",
                    "expression": "neutral",
                    "position": "center",
                    "isSpeaking": false
                }
            ],
            "text": "...Jadi... selama ini aku sendirian?",
            "next": "scene12_n018"
        },
        {
            "id": "scene12_n018",
            "type": "line",
            "speaker": "alaric",
            "expression": "neutral",
