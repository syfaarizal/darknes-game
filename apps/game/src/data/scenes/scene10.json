    "nodes":  [
                  {
                      "id":  "scene10_n001",
                      "type":  "narration",
                      "text":  "Mobil berhenti di depan sebuah mansion tua yang berdiri megah di pinggir danau. Seorang pria paruh baya telah menunggu di depan pintu utama. Rambutnya mulai memutih. Senyumnya hangat. Tatapannya tenang.",
                      "next":  "scene10_n002"
                  },
                  {
                      "id":  "scene10_n002",
                      "type":  "line",
                      "speaker":  "victor",
                      "expression":  "smile",
                      "characters":  [
                                         {
                                             "characterId":  "victor",
                                             "expression":  "smile",
                                             "position":  "center",
                                             "isSpeaking":  true
                                         }
                                     ],
                      "text":  "Sudah lama aku ingin bertemu langsung dengan putri Samuel Ravenscroft.",
                      "next":  "scene10_n003"
                  },
                  {
                      "id":  "scene10_n003",
                      "type":  "line",
                      "speaker": "{playerName}",
                      "expression":  "smile",
                      "characters":  [
                                         {
                                             "characterId":  "victor",
                                             "expression":  "smile",
                                             "position":  "center",
                                             "isSpeaking":  false
                                         }
                                     ],
                      "text":  "(tersenyum tipis) Selamat sore, Tuan.",
                      "next":  "scene10_n004"
                  },
                  {
                      "id":  "scene10_n004",
                      "type":  "line",
                      "speaker":  "victor",
                      "expression":  "smile",
                      "characters":  [
                                         {
                                             "characterId":  "victor",
                                             "expression":  "smile",
                                             "position":  "center",
                                             "isSpeaking":  true
                                         }
                                     ],
                      "text":  "(tersenyum) Masuklah. Anggap saja rumah sendiri.",
                      "next":  "scene10_n005"
                  },
                  {
                      "id":  "scene10_n005",
                      "type":  "narration",
                      "text":  "{playerName} terus mengamati seluruh ruangan. Beberapa saat kemudian, mereka duduk di ruang tamu. Seorang pelayan menyajikan teh. Victor menuangkan teh ke cangkir {playerName}.",
                      "next":  "scene10_n006"
                  },
                  {
                      "id":  "scene10_n006",
                      "type":  "line",
                      "speaker":  "victor",
                      "expression":  "smile",
                      "characters":  [
                                         {
                                             "characterId":  "victor",
                                             "expression":  "smile",
                                             "position":  "center",
                                             "isSpeaking":  true
                                         }
                                     ],
                      "text":  "Ayahmu dulu selalu memilih teh yang sama.",
                      "next":  "scene10_n007"
                  },
                  {
                      "id":  "scene10_n007",
                      "type":  "line",
                      "speaker": "{playerName}",
                      "expression":  "neutral",
                      "characters":  [
                                         {
                                             "characterId":  "victor",
                                             "expression":  "neutral",
                                             "position":  "center",
                                             "isSpeaking":  false
                                         }
                                     ],
                      "text":  "Menatap cangkirnya... Begitu?",
                      "next":  "scene10_n008"
                  },
                  {
                      "id":  "scene10_n008",
                      "type":  "line",
                      "speaker":  "victor",
                      "expression":  "smile",
                      "characters":  [
                                         {
                                             "characterId":  "victor",
                                             "expression":  "smile",
                                             "position":  "center",
                                             "isSpeaking":  true
                                         }
                                     ],
                      "text":  "(tersenyum kecil) Samuel punya selera yang sederhana. Tapi kepalanya sangat keras.",
                      "next":  "scene10_n009"
                  },
                  {
                      "id":  "scene10_n009",
                      "type":  "line",
                      "speaker": "{playerName}",
                      "expression":  "neutral",
                      "characters":  [
                                         {
                                             "characterId":  "victor",
                                             "expression":  "neutral",
                                             "position":  "center",
                                             "isSpeaking":  false
                                         }
                                     ],
                      "text":  "Berarti hubungan Anda cukup dekat.",
                      "next":  "scene10_n010"
                  },
                  {
                      "id":  "scene10_n010",
                      "type":  "line",
                      "speaker":  "victor",
                      "expression":  "smile",
                      "characters":  [
                                         {
                                             "characterId":  "victor",
                                             "expression":  "smile",
                                             "position":  "center",
                                             "isSpeaking":  true
                                         }
                                     ],
                      "text":  "(tertawa pelan) Cukup dekat. Dulu kami sering berdiskusi soal bisnis. Lalu... jalan kami berbeda.",
                      "next":  "scene10_n011"
                  },
                  {
                      "id":  "scene10_n011",
                      "type":  "choice",
                      "options":  [
                                      {
                                          "text":  "Ayah tidak pernah menceritakan Anda",
                                          "goTo":  "scene10_n012a"
                                      },
                                      {
                                          "text":  "Hubungan kalian berakhir buruk?",
                                          "goTo":  "scene10_n012b"
                                      },
                                      {
                                          "text":  "Apa terakhir kali kalian bertemu... malam itu?",
                                          "goTo":  "scene10_n012c"
                                      }
                                  ]
                  },
                  {
                      "id":  "scene10_n012a",
                      "type":  "line",
                      "speaker":  "victor",
                      "expression":  "neutral",
                      "characters":  [
                                         {
                                             "characterId":  "victor",
                                             "expression":  "neutral",
                                             "position":  "center",
                                             "isSpeaking":  true
                                         }
                                     ],
                      "text":  "(terdiam sejenak) Malam itu... adalah malam yang ingin kulupakan. Aku datang terlambat. Ketika sampai... semuanya sudah selesai.",
                      "next":  "scene10_n013"
                  },
                  {
                      "id":  "scene10_n012b",
                      "type":  "line",
                      "speaker":  "victor",
                      "expression":  "neutral",
                      "characters":  [
                                         {
                                             "characterId":  "victor",
                                             "expression":  "neutral",
                                             "position":  "center",
                                             "isSpeaking":  true
                                         }
                                     ],
                      "text":  "(terdiam sejenak) Malam itu... adalah malam yang ingin kulupakan. Aku datang terlambat. Ketika sampai... semuanya sudah selesai.",
                      "next":  "scene10_n013"
                  },
                  {
                      "id":  "scene10_n012c",
