                                             "position":  "center",
                                             "isSpeaking":  true
                                         }
                                     ],
                      "text":  "(terdiam sejenak) Malam itu... adalah malam yang ingin kulupakan. Aku datang terlambat. Ketika sampai... semuanya sudah selesai.",
                      "next":  "scene10_n013"
                  },
                  {
                      "id":  "scene10_n013",
                      "type":  "narration",
                      "text":  "{playerName} memperhatikan ekspresi Victor. Tidak ada keraguan. Tidak ada kepanikan. Seolah ia telah mengulang cerita itu ratusan kali. Victor mengganti topik pembicaraan.",
                      "next":  "scene10_n014"
                  },
                  {
                      "id":  "scene10_n014",
                      "type":  "line",
                      "speaker":  "victor",
                      "expression":  "smile",
                      "characters":  [
                                         {
                                             "characterId":  "victor",
                                             "expression":  "smile",
                                             "position":  "center",
                                             "isSpeaking":  true
                                         }
                                     ],
                      "text":  "Ngomong-ngomong... bagaimana kabar Alaric?",
                      "next":  "scene10_n015"
                  },
                  {
                      "id":  "scene10_n015",
                      "type":  "choice",
                      "options":  [
                                      {
                                          "text":  "Anda mengenalnya?",
                                          "goTo":  "scene10_n016a"
                                      },
                                      {
                                          "text":  "Dia baik",
                                          "goTo":  "scene10_n016b"
                                      },
                                      {
                                          "text":  "Kenapa bertanya tentang dia?",
                                          "goTo":  "scene10_n016c"
                                      }
                                  ]
                  },
                  {
                      "id":  "scene10_n016a",
                      "type":  "line",
                      "speaker":  "victor",
                      "expression":  "smile",
                      "characters":  [
                                         {
                                             "characterId":  "victor",
                                             "expression":  "smile",
                                             "position":  "center",
                                             "isSpeaking":  true
                                         }
                                     ],
                      "text":  "(tersenyum ramah) Anak itu sering mengunjungiku. Dari dulu. Dia anak yang polos. Selalu bercerita banyak hal.",
                      "next":  "scene10_n017"
                  },
                  {
                      "id":  "scene10_n016b",
