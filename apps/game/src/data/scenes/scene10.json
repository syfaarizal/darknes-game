                                             "position":  "center",
                                             "isSpeaking":  true
                                         }
                                     ],
                      "text":  "(mengangguk pelan) Peduli... Itu sifat yang langka. Sama seperti ayahmu.",
                      "next":  "scene10_n021"
                  },
                  {
                      "id":  "scene10_n021",
                      "type":  "narration",
                      "text":  "Ruangan kembali hening. Beberapa detik berlalu. Victor kembali berbicara.",
                      "next":  "scene10_n022"
                  },
                  {
                      "id":  "scene10_n022",
                      "type":  "line",
                      "speaker":  "victor",
                      "expression":  "neutral",
                      "characters":  [
                                         {
                                             "characterId":  "victor",
                                             "expression":  "neutral",
                                             "position":  "center",
                                             "isSpeaking":  true
                                         }
                                     ],
                      "text":  "Kadang aku berpikir... Kalau saja Samuel tidak mudah mempercayai orang lain... mungkin malam itu tidak akan terjadi.",
                      "next":  "scene10_n023"
                  },
                  {
                      "id":  "scene10_n023",
                      "type":  "line",
                      "speaker": "{playerName}",
                      "expression":  "neutral",
                      "characters":  [
                                         {
                                             "characterId":  "victor",
                                             "expression":  "neutral",
                                             "position":  "center",
                                             "isSpeaking":  false
                                         }
                                     ],
                      "text":  "(mengerutkan dahi) Apa maksud Anda?",
                      "next":  "scene10_n024"
                  },
                  {
                      "id":  "scene10_n024",
                      "type":  "line",
                      "speaker":  "victor",
                      "expression":  "smile",
                      "characters":  [
                                         {
                                             "characterId":  "victor",
                                             "expression":  "smile",
                                             "position":  "center",
                                             "isSpeaking":  true
                                         }
                                     ],
                      "text":  "(hanya tersenyum) Ah... Mungkin hanya penyesalan orang tua.",
                      "next":  "scene10_n025"
                  },
                  {
                      "id":  "scene10_n025",
                      "type":  "narration",
                      "text":  "Ia berdiri.",
                      "next":  "scene10_n026"
                  },
                  {
                      "id":  "scene10_n026",
                      "type":  "line",
                      "speaker":  "victor",
                      "expression":  "smile",
                      "characters":  [
                                         {
                                             "characterId":  "victor",
                                             "expression":  "smile",
                                             "position":  "center",
                                             "isSpeaking":  true
                                         }
                                     ],
                      "text":  "Maaf, aku harus menerima telepon sebentar. Silakan nikmati tehnya.",
                      "next":  "scene10_n027"
                  },
                  {
                      "id":  "scene10_n027",
                      "type":  "narration",
                      "text":  "Ia berjalan meninggalkan ruang tamu. Pintu perlahan tertutup. {playerName} terdiam. Ia mengingat kembali ucapan Victor. \u0027Alaric sering mengunjungiku.\u0027 Tangannya perlahan mengepal.",
                      "next":  "scene10_end"
                  },
                  {
