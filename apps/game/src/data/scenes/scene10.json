                                             "isSpeaking":  true
                                         }
                                     ],
                      "text":  "(tersenyum ramah) Anak itu sering mengunjungiku. Dari dulu. Dia anak yang polos. Selalu bercerita banyak hal.",
                      "next":  "scene10_n017"
                  },
                  {
                      "id":  "scene10_n016c",
