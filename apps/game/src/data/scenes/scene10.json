                                             "isSpeaking":  true
                                         }
                                     ],
                      "text":  "(tersenyum ramah) Anak itu sering mengunjungiku. Dari dulu. Dia anak yang polos. Selalu bercerita banyak hal.",
                      "next":  "scene10_n017"
                  },
                  {
                      "id":  "scene10_n017",
                      "type":  "line",
                      "speaker":  "victor",
                      "expression":  "smile",
                      "characters":  [
                                         {
                                             "characterId":  "victor",
                                             "expression":  "smile",
                                             "position":  "center",
                                             "isSpeaking":  true
                                         }
                                     ],
                      "text":  "Dia sering khawatir padamu. Katanya... kau sering lupa makan dan terlalu banyak bekerja.",
                      "next":  "scene10_n018"
                  },
                  {
                      "id":  "scene10_n018",
                      "type":  "narration",
                      "text":  "{playerName} menggenggam cangkirnya sedikit lebih erat.",
                      "next":  "scene10_n019"
                  },
                  {
                      "id":  "scene10_n019",
                      "type":  "choice",
                      "options":  [
                                      {
                                          "text":  "Dia memang seperti itu",
                                          "goTo":  "scene10_n020a"
                                      },
                                      {
                                          "text":  "Dia terlalu banyak bicara",
                                          "goTo":  "scene10_n020b"
                                      },
                                      {
                                          "text":  "Dia hanya peduli",
                                          "goTo":  "scene10_n020c"
                                      }
                                  ]
                  },
                  {
                      "id":  "scene10_n020a",
                      "type":  "line",
                      "speaker":  "victor",
                      "expression":  "smile",
                      "characters":  [
                                         {
                                             "characterId":  "victor",
                                             "expression":  "smile",
                                             "position":  "center",
                                             "isSpeaking":  true
                                         }
                                     ],
                      "text":  "(mengangguk pelan) Peduli... Itu sifat yang langka. Sama seperti ayahmu.",
                      "next":  "scene10_n021"
                  },
                  {
                      "id":  "scene10_n020b",
