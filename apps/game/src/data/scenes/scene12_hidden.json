    "nodes":  [
                  {
                      "id":  "scene12_hidden_n001",
                      "type":  "narration",
                      "text":  "Gelap. {playerName} membuka mata. Di hadapannya, ada Nathael.",
                      "next":  "scene12_hidden_n002"
                  },
                  {
                      "id":  "scene12_hidden_n002",
                      "type":  "line",
                      "speaker":  "player",
                      "expression":  "neutral",
                      "characters":  [
                                         {
                                             "characterId":  "nathael",
                                             "expression":  "neutral",
                                             "position":  "center",
                                             "isSpeaking":  false
                                         }
                                     ],
                      "text":  "Kita di mana?",
                      "next":  "scene12_hidden_n003"
                  },
                  {
                      "id":  "scene12_hidden_n003",
                      "type":  "line",
                      "speaker":  "nathael",
                      "expression":  "smile",
                      "characters":  [
                                         {
                                             "characterId":  "nathael",
                                             "expression":  "smile",
                                             "position":  "center",
                                             "isSpeaking":  true
                                         }
                                     ],
                      "text":  "(tersenyum) Tempat ini tidak seharusnya kamu datangi secepat ini. Tapi ada seseorang... yang ingin bertemu.",
                      "next":  "scene12_hidden_n004"
                  },
                  {
                      "id":  "scene12_hidden_n004",
                      "type":  "narration",
                      "text":  "Ia mengulurkan tangan. Mereka berjalan. Sampai di sebuah taman. Di bawah pohon besar...",
                      "next":  "scene12_hidden_n005"
                  },
                  {
                      "id":  "scene12_hidden_n005",
                      "type":  "narration",
                      "text":  "Samuel dan ibunya berdiri. {playerName} terkejut, matanya berkaca-kaca. Ia berlari dan langsung memeluk mereka. Tangisnya pecah.",
                      "next":  "scene12_hidden_n006"
                  },
                  {
                      "id":  "scene12_hidden_n006",
                      "type":  "line",
                      "speaker":  "player",
                      "expression":  "neutral",
                      "characters":  [
                                         {
                                             "characterId":  "father",
                                             "expression":  "neutral",
                                             "position":  "center",
                                             "isSpeaking":  true
                                         }
                                     ],
                      "text":  "Aku merindukan kalian.",
                      "next":  "scene12_hidden_n007"
                  },
                  {
                      "id":  "scene12_hidden_n007",
                      "type":  "line",
                      "speaker":  "mother",
                      "expression":  "neutral",
                      "characters":  [
                                         {
                                             "characterId":  "mother",
                                             "expression":  "neutral",
                                             "position":  "center",
                                             "isSpeaking":  true
                                         }
                                     ],
                      "text":  "(mengusap rambutnya) Kami juga.",
                      "next":  "scene12_hidden_n008"
                  },
                  {
                      "id":  "scene12_hidden_n008",
                      "type":  "line",
                      "speaker":  "father",
                      "expression":  "smile",
                      "characters":  [
                                         {
                                             "characterId":  "father",
                                             "expression":  "smile",
                                             "position":  "center",
                                             "isSpeaking":  true
                                         }
                                     ],
                      "text":  "(tersenyum) Kau hebat sekali, anakku.",
                      "next":  "scene12_hidden_n009"
                  },
                  {
                      "id":  "scene12_hidden_n009",
                      "type":  "line",
                      "speaker":  "player",
                      "expression":  "smile",
                      "characters":  [
                                         {
                                             "characterId":  "father",
                                             "expression":  "smile",
                                             "position":  "center",
                                             "isSpeaking":  false
                                         }
                                     ],
                      "text":  "(tersenyum) Iya. (menoleh kepada Nathael) Dia selalu menemaniku di saat aku merasa sendiri.",
                      "next":  "scene12_hidden_n010"
                  },
                  {
                      "id":  "scene12_hidden_n010",
                      "type":  "line",
                      "speaker":  "father",
                      "expression":  "smile",
                      "characters":  [
                                         {
                                             "characterId":  "father",
                                             "expression":  "smile",
                                             "position":  "center",
                                             "isSpeaking":  true
                                         }
                                     ],
                      "text":  "(tersenyum hangat) Setelah malam itu... Kami tidak bisa lagi menjagamu.",
                      "next":  "scene12_hidden_n011"
                  },
                  {
                      "id":  "scene12_hidden_n011",
                      "type":  "line",
                      "speaker":  "mother",
                      "expression":  "neutral",
                      "characters":  [
                                         {
                                             "characterId":  "mother",
                                             "expression":  "neutral",
                                             "position":  "center",
                                             "isSpeaking":  true
                                         }
                                     ],
                      "text":  "Jadi... Hatimu menciptakan seseorang... yang bisa menggantikan kami. Seseorang itu adalah Nathael.",
                      "next":  "scene12_hidden_n012"
                  },
                  {
                      "id":  "scene12_hidden_n012",
                      "type":  "line",
                      "speaker":  "nathael",
                      "expression":  "smile",
                      "characters":  [
                                         {
                                             "characterId":  "nathael",
                                             "expression":  "smile",
                                             "position":  "center",
                                             "isSpeaking":  true
                                         }
                                     ],
                      "text":  "Aku bukan ayahmu. Aku bukan ibumu. Aku hanyalah... wujud kasih sayang yang tidak sempat mereka berikan.",
                      "next":  "scene12_hidden_n013"
                  },
                  {
                      "id":  "scene12_hidden_n013",
                      "type":  "line",
                      "speaker":  "player",
                      "expression":  "neutral",
                      "characters":  [
                                         {
                                             "characterId":  "nathael",
                                             "expression":  "smile",
                                             "position":  "center",
                                             "isSpeaking":  false
                                         }
                                     ],
                      "text":  "(menangis) Terima kasih...",
                      "next":  "scene12_hidden_n014"
                  },
                  {
                      "id":  "scene12_hidden_n014",
                      "type":  "narration",
                      "text":  "Nathael mengusap kepala {playerName}, seperti yang selalu ia lakukan.",
                      "next":  "scene12_hidden_n015"
                  },
                  {
                      "id":  "scene12_hidden_n015",
                      "type":  "line",
                      "speaker":  "nathael",
                      "expression":  "neutral",
                      "characters":  [
                                         {
                                             "characterId":  "nathael",
                                             "expression":  "neutral",
                                             "position":  "center",
                                             "isSpeaking":  true
                                         }
                                     ],
                      "text":  "Sekarang... mereka yang akan menjagamu.",
                      "next":  "scene12_hidden_n016"
                  },
                  {
                      "id":  "scene12_hidden_n016",
                      "type":  "narration",
                      "text":  "Perlahan, tubuh Nathael menghilang yang menyatu dengan pelukan kedua orang tua {playerName}. Cahaya putih memenuhi layar.",
                      "next":  "scene12_hidden_end"
                  },
                  {
                      "id":  "scene12_hidden_end",
                      "type":  "end",
                      "endingId":  "hidden-ending"
                  }
              ]
